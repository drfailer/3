~~~ raylib bindings for 3

~~~ Note for the Color:
~~~ 3 does not support compound litteral yet, however, the Color struct is 4
~~~ bytes long:
~~~ struct Color { char r; char g; char b; char a; };
~~~ which means that it gets passed to functions through registers (according to
~~~ the C calling convention), therefore, we can cheat by using an int (in 3,
~~~ `int` is a 64 bits signed integer).

dcl nil InitWindow(int width, int height, str title)
dcl nil CloseWindow()
dcl int WindowShouldClose()
dcl int BeginDrawing()
dcl int EndDrawing()
dcl int ClearBackground(int color)
dcl int DrawText(str text, int posx, int posy, int font_size, int color)
dcl int MeasureText(str text, int font_size)
