~~~ fibonacci function
int fib(int n) bgn
    int fnn
    int fnn1
    int fnn2
    mov(fnn2, 1)
    mov(fnn1, 1)

    cnd ieq(n, 2) bgn
        ret n
    end otw bgn
        int i

        for i rng(2, n, 1) bgn
            mov(fnn, add(fnn1, fnn2))
            mov(fnn2, fnn1)
            mov(fnn1, fnn)
        end
        ret fnn
    end
end

nil main() bgn
    int n
    shw("Enter a number:\n")
    ipt(n)
    shw("fib of n is: ")
    mov(n, fib(n))
    shw(n)
    shw("\n")
end
