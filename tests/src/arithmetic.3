use ../../utilities/print/print

nil integers() bgn
    int a
    int b
    int c

    shw("testing integers:\n")

    ~~~ setup
    mov(a, 4)
    mov(b, 6)
    mov(c, 0)
    shw("a = ")
    print_int(a)
    shw("\n")
    shw("b = ")
    print_int(b)
    shw("\n")
    shw("c = ")
    print_int(c)
    shw("\n")

    ~~~ add
    shw("a + b = ")
    print_int(add(a, b))
    shw("\n")

    ~~~ sub
    shw("a - b = ")
    print_int(sub(a, b))
    shw("\n")

    ~~~ mul
    shw("a * b = ")
    print_int(mul(a, b))
    shw("\n")

    ~~~ div
    shw("b / a = ")
    print_int(div(b, a))
    shw("\n")

    ~~~ multiple operations
    shw("c + (a * 2 * 2) / (b - a) = ")
    mov(c, add(c, div(mul(a, mul(2, 2)), sub(b, a))))
    print_int(c)
    shw("\n")
end

