test_cnd(1, 1, 0) -> [1, 3, 7, 10]:
* [1] eql(a, b)
* [3] not eql(a, mul(b, 2))
* [7] eql(a, add(b, c))
* [10] eql(a, add(b, c))
test_cnd(2, 1, 2) -> [2, 4, 6, 9]:
* [2] eql(a, mul(b, 2))
* [4] eql(a, c)
* [6] eql(a, c)
* [9] eql(a, c)
test_cnd(4, 2, 2) -> [2, 5, 7, 10]:
* [2] eql(a, mul(b, 2))
* [5] eql(mul(b, c), a)
* [7] eql(a, add(b, c))
* [10] eql(a, add(b, c))
test_cnd(4, 6, 2) -> [3, 8, 11]:
* [3] not eql(a, mul(b, 2))
* [8] eql(a, sub(b, c))
* [11] eql(a, sub(b, c))
test_cnd(10, 0, 0) -> [3, 12]:
* [3] not eql(a, mul(b, 2))
* [12] end
