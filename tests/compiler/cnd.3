int main() bgn
    int a
    int b

    mov(a, 3)
    mov(b, 9)

    cnd eql(a, b) bgn
        shw("a == b\n")
    otw
        cnd eql(b, mul(a, a)) bgn
            shw("a != b\n")
        end
    end

    cnd eql(a, b) bgn
        shw("a == b\n")
    otw eql(b, mul(a, a))
        shw("a != b\n")
    otw
        shw("otw")
    end

    cnd eql(b, mul(a, a)) bgn
        shw("b == a*a\n")
    end

    ret 0
end
